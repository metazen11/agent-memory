# agent-memory configuration
# Generated by install.js — edit as needed

# PostgreSQL
POSTGRES_USER=agentmem
POSTGRES_PASSWORD=        # REQUIRED — auto-generated by install.js
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=agent_memory

# Or specify full URL (overrides components above)
# DATABASE_URL=postgresql://user:pass@host:port/db

# Embeddings (auto-downloaded on install)
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# Observation LLM — leave blank to skip local LLM (uses Anthropic Haiku)
OBSERVATION_LLM_MODEL=

# Anthropic API — required if OBSERVATION_LLM_MODEL is empty
ANTHROPIC_API_KEY=

# Server
HOST=0.0.0.0
PORT=3377

# Queue worker
QUEUE_POLL_INTERVAL=5
QUEUE_MAX_RETRIES=3
