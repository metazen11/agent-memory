# agent-memory configuration

# PostgreSQL (reuses agentmz Docker Postgres)
DATABASE_URL=postgresql://wfhub:yourpassword@localhost:5433/agentic

# Ollama (reuses agentic-ollama Docker container)
OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# Observation LLM (Anthropic preferred, Ollama fallback)
# Set ANTHROPIC_API_KEY for high-quality observations via Haiku
# If unset, falls back to Ollama local model
ANTHROPIC_API_KEY=
OBSERVATION_LLM_MODEL=claude-haiku-4-5-20251001
OLLAMA_LLM_MODEL=gemma3:4b

# Server
HOST=0.0.0.0
PORT=3377

# Queue worker
QUEUE_POLL_INTERVAL=5
QUEUE_MAX_RETRIES=3
